#alias nano=vim; # Evil

source ~/.year_progress;

if [ -f ~/.cargo/env ]; then
	source ~/.cargo/env;
fi

if [ -f ~/.restic ]; then
	source ~/.restic;
fi

function neofetch {
	/usr/bin/neofetch $1 | sed "s/i[0-7]-/i3-/g" | sed "s/HQ//g" | sed "s/20ENCTO1WW ThinkPad P50/ThiccPad E50/g" | sed "s/NVIDIA Quadro M2000M/NVIDIA 9400GT/g" | sed "s/31906/7977/g";
}

function uname {
	/usr/bin/uname $1 | sed "s/i[0-7]-/i3-/g" | sed "s/HQ//g" | sed "s/GenuineIntel/ShintelPanic/g" | sed "s/Intel/Shintel/g" | sed "s/MHz/THz/g";
}

function lscpu {
	/usr/bin/lscpu $1 | sed "s/i[0-7]-/i3-/g" | sed "s/HQ//g" | sed "s/GenuineIntel/ShintelPanic/g" | sed "s/Intel/Shintel/g" | sed "s/MHz/THz/g" | sed "s/Little Endian/Random Endian/g" | sed "s/GHz/PHz/g";
}
