# Start tmux
if [[ "${TMUX}" == "" && "$1" == "" ]]; then
	# Display a dialog
	exec 3>&1;
	local result=$(dialog --backtitle "Start tmux?" --menu "Options" 10 30 2 1 Start\ tmux 2 Attach\ tmux 2>&1 1>&3);
	exec 3>&-;

	# Start tmux
	case $result in
		"1")
			/usr/bin/tmux new;
			exit $?;
			;;
		"2")
			/usr/bin/tmux attach || /usr/bin/tmux new;
			exit $?;
			;;
		*)
			clear;
			source ~/.source;
			;;
	esac
else
	source ~/.source;
fi
